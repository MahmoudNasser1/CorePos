# نسخ إلى `.env.local` وعدم رفع الأسرار إلى git

# رابط تطبيق الواجهة (للميتاداتا والروابط المطلقة)
NEXT_PUBLIC_APP_URL=http://localhost:4001

# عنوان API للباكند (يجب أن يطابق BACKEND_PORT في apps/backend/.env — الافتراضي 4000)
# — للاستدعاء من الخادم (RSC، middleware، /api/*)
BACKEND_API_URL=http://localhost:4000
# — لصفحات «use client» (تسجيل الدخول من المتصفح)
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:4000

# دعم واتساب: أرقام فقط مع رمز الدولة (مثال مصر: 2010xxxxxxxx)
# يظهر رابط واتساب في تذييل صفحات تسجيل الدخول/التسجيل عند التعيين
NEXT_PUBLIC_SUPPORT_WHATSAPP=201113511940
