{
  "name": "@pos-sahl/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run build && npm run start",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/main.js",
    "openapi:generate": "npm run build && node dist/generate-openapi.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "contract:smoke": "npm run build && tsx tests/contract/contract-smoke.ts",
    "security:smoke": "npm run build && tsx tests/security/security-smoke.ts",
    "stress:pos-sale": "npm run build && tsx tests/stress/pos-sale-stress.ts",
    "soak:pos-sale": "npm run build && tsx tests/stress/pos-sale-soak.ts",
    "idempotency:conflict": "npm run build && tsx tests/stress/idempotency-conflict.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@types/pg": "^8.15.5",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.44.6",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@nestjs/testing": "^11.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
