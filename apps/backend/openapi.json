  "info": {
    "title": "CorePOS Backend API",
    "description": "Backend migration service from Supabase to NestJS",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@pos-sahl.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          },
          "fullName": {
            "type": "string",
            "example": "محمود"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateSaleInvoiceItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "example": "uuid-product"
          },
          "qty": {
            "type": "number",
            "example": 1
          },
          "unitPrice": {
            "type": "number",
            "example": 10
          },
          "totalLine": {
            "type": "number",
            "example": 10
          }
        },
        "required": [
          "productId",
          "qty",
          "unitPrice",
          "totalLine"
        ]
      },
      "CreateSaleInvoiceDto": {
        "type": "object",
        "properties": {
          "branchId": {
            "type": "string",
            "example": "uuid-branch"
          },
          "warehouseId": {
            "type": "string",
            "example": "uuid-warehouse"
          },
          "customerId": {
            "type": "object",
            "example": "uuid-customer",
            "nullable": true
          },
          "cashierId": {
            "type": "string",
            "example": "uuid-cashier"
          },
          "subtotal": {
            "type": "number",
            "example": 10
          },
          "discountAmount": {
            "type": "number",
            "example": 0
          },
          "taxAmount": {
            "type": "number",
            "example": 0
          },
          "total": {
            "type": "number",
            "example": 10
          },
          "paid": {
            "type": "number",
            "example": 10
          },
          "remaining": {
