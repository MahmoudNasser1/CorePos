# انسخ إلى apps/backend/.env وعدّل القيم

# Postgres — مطلوب لتسجيل الدخول والعمليات
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/pos_sahl

# سر JWT (في الإنتاج استخدم قيمة عشوائية قوية)
JWT_SECRET=dev-change-me

# منفذ الـ API (افتراضي 4000). إن كان المنفذ مشغولاً عندك (تعارض مع أداة أخرى):
# غيّر إلى 4010 مثلاً، وحدّث في جذر المشروع `.env.local` القيمتين:
#   BACKEND_API_URL=http://localhost:4010
#   NEXT_PUBLIC_BACKEND_API_URL=http://localhost:4010
BACKEND_PORT=4000
